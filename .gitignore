# --- Python build artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.h5

# --- Logs (all log files including rotated backups) ---
*.log
*.log.*

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Gradio temp files ---
.gradio/

# --- Application runtime directories ---
inputs/
outputs/
temp/
temp_gif_frames/
temp_gif_enhanced/

# --- Cache directories ---
cache/
*.cache
tensorrt_cache/

# --- Tests (exclude pycache and test outputs, but track test files) ---
tests/__pycache__/
tests/**/__pycache__/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# --- Config/environment for local machine only ---
*.env

# --- Claude Code local files ---
.claude/

# --- Agent / IDE local state (not for remote) ---
.opencode/
.planning/
.grok/

# --- Generated dc-runtime bundle (rebuild locally; not wired into app) ---
ui/support.js

# --- Model weights (large files) ---
# (Commit ONLY if under 100MB or tracked via git-lfs)
models/**/*.pth
models/**/*.pt
models/**/*.onnx

# GFPGAN weights (large model files)
gfpgan/

# But keep your **main ONNX swapper** (if under 100MB) by explicitly negating
!inswapper_128.onnx

# --- External dependencies (now using pip packages) ---
external/Real-ESRGAN/
external/**/.git

# --- OS / Editor junk ---
.DS_Store
Thumbs.db
*.swp

# --- Node / frontend (if present later) ---
node_modules/
dist/
build/
inswapper_128_optimized.onnx

# --- Internal docs (kept local, not published to GitHub) ---
AGENTS.md
BLUEPRINT.md
CLAUDE.md
PROJECT_INTENT.md
scripts/PROGRESS_TRACKING.md

# --- Windows copy cruft & local setup artifacts ---
*Zone.Identifier
*.deb
